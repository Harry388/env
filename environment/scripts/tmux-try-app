#!/usr/bin/env bash

session=$(tmux display-message -p "#{session_name}")
app="$1"
window="$session:$2"

if ! tmux select-window -t "$window" &> /dev/null; then
    tmux neww -t "$window" -d
    if [ -n "$app" ]; then
        tmux send-keys -t "$window" "$app" c-M
    fi
    tmux select-window -t "$window"
fi
