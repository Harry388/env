#!/usr/bin/env bash

command="$1"

if [ -z "$command" ] || ! { [ "$command" = "toggle-pin" ] || [ "$command" = "toggle-display" ] || [ "$command" = "toggle-orientation" ] || [ "$command" = "sync" ] || [ "$command" = "resize" ] || [ "$command" = "test" ]; }; then
    echo "Usage: $(basename "$0") <toggle-pin|toggle-display|toggle-orientation|sync|resize|test> [sync target]"
    exit 1
fi

if [ -z "$XDG_STATE_HOME" ]; then
    XDG_STATE_HOME="$HOME/.local/state"
fi

if [ -z "$COLLAPSE_WINDOW" ]; then
    COLLAPSE_WINDOW=":98"
fi

if [ -z "$DEFAULT_SIZE" ]; then
    DEFAULT_SIZE="30%"
fi

if [ -z "$DEFAULT_ORIENTATION" ]; then
    DEFAULT_ORIENTATION="vertical"
fi

if [ -z "$DEFAULT_DISPLAY" ]; then
    DEFAULT_DISPLAY="show"
fi

get_pane_width() {
    target_pane_id="$1"
    w_width=$(tmux display-message -t "$target_pane_id" -p "#{window_width}")
    p_width=$(tmux display-message -t "$target_pane_id" -p "#{pane_width}")
    echo "$(( (p_width * 100) / w_width ))%"
}

get_pane_height() {
    target_pane_id="$1"
    w_height=$(tmux display-message -t "$target_pane_id" -p "#{window_height}")
    p_height=$(tmux display-message -t "$target_pane_id" -p "#{pane_height}")
    echo "$(( (p_height * 100) / w_height ))%"
}

read_session_file() {
    session_file="$1"
    {
        read -r pin_pane
        read -r size
        read -r display
        read -r orientation
    } < "$session_file"
}

write_session_file() {
    session_file="$1"
    pin_pane="$2"
    size="$3"
    display="$4"
    orientation="$5"

    echo -e "$pin_pane\n$size\n$display\n$orientation" > "$session_file"
}

sync_pane() {
    pin_pane="$1"
    size="$2"
    display="$3"
    orientation="$4"
    target="$5"

    detach="-d"
    if [ "$display" = "show" ]; then
        if [ -z "$target" ]; then
            if [ "$orientation" = "vertical" ]; then
                target="$window_id.{bottom}"
            else
                target="$window_id.{left}"
            fi
        fi
        if tmux has-session -t "$COLLAPSE_WINDOW"; then
            tmux kill-pane -t "$COLLAPSE_WINDOW"
            detach=""
        fi
    else
        if ! tmux has-session -t "$COLLAPSE_WINDOW"; then
            tmux neww -t "$COLLAPSE_WINDOW" -d
        fi
        target="$COLLAPSE_WINDOW"
        if [ "$orientation" = "vertical" ]; then
            target="$target.{bottom}"
        else
            target="$target.{left}"
        fi
    fi
    split="-v"
    if [ "$orientation" = "horizontal" ]; then
        split="-hb"
    fi
    target_pane_id=$(tmux display-message -t "$target" -p "#{pane_id}")
    if [ "$target_pane_id" = "$pin_pane" ]; then
        return 0
    fi
    if [ -n "$size" ]; then
        size_option=(-l "$size")
    else
        size_option=()
    fi
    tmux join-pane $detach $split -s "$pin_pane" -t "$target" "${size_option[@]}"
}

sync_pane_from_file() {
    session_file="$1"
    target="$2"
    if ! [ -f "$session_file" ]; then
        return 0
    fi
    read_session_file "$session_file"
    if ! tmux has-session -t "$pin_pane"; then
        rm "$session_file"
        return 0
    fi
    sync_pane "$pin_pane" "$size" "$display" "$orientation" "$target"
}

session=$(tmux display-message -p "#{session_name}")
pane_id=$(tmux display-message -p "#{pane_id}")
window_id=$(tmux display-message -p "#{window_id}")

if [ -z "$pane_id" ] || [ -z "$session" ] || [ -z "$window_id" ]; then
    exit 1
fi

session_file="$XDG_STATE_HOME/tmux-pin-pane/$session"

if ! [ -d "$XDG_STATE_HOME/tmux-pin-pane" ]; then
    mkdir -p "$XDG_STATE_HOME/tmux-pin-pane"
fi

if [ "$command" = "toggle-pin" ]; then
    if [ -f "$session_file" ]; then
        read -r pin_pane < "$session_file"
        if [ "$pane_id" = "$pin_pane" ]; then
            rm "$session_file"
            exit 0
        fi
    fi
    sync_pane "$pane_id" "" "$DEFAULT_DISPLAY" "$DEFAULT_ORIENTATION" ""
    sleep 0.5
    size=$(get_pane_height "$pane_id")
    if [ "$size" = "100%" ]; then
        size="$DEFAULT_SIZE"
    fi
    write_session_file "$session_file" "$pane_id" "$size" "$DEFAULT_DISPLAY" "$DEFAULT_ORIENTATION"
elif [ "$command" = "sync" ]; then
    sync_pane_from_file "$session_file" "$2"
elif [ "$command" = "resize" ]; then
    if ! [ -f "$session_file" ]; then
        exit 0
    fi
    read_session_file "$session_file"
    if ! tmux has-session -t "$pin_pane"; then
        rm "$session_file"
        exit 0
    fi
    sleep 0.5
    if [ "$orientation" = "vertical" ]; then
        size="$(get_pane_height "$pin_pane")"
    else
        size="$(get_pane_width "$pin_pane")"
    fi
    if [ "$size" = "100%" ]; then
        size="$DEFAULT_SIZE"
    fi
    write_session_file "$session_file" "$pin_pane" "$size" "$display" "$orientation"
elif [ "$command" = "toggle-display" ]; then
    if ! [ -f "$session_file" ]; then
        tmux split-window -v -t "$window_id.{bottom}" -l "$DEFAULT_SIZE"
        "$0" toggle-pin
        exit 0
    fi
    read_session_file "$session_file"
    if [ "$display" = "show" ]; then
        display="hide"
    else
        display="show"
    fi
    write_session_file "$session_file" "$pin_pane" "$size" "$display" "$orientation"
    sync_pane_from_file "$session_file"
elif [ "$command" = "toggle-orientation" ]; then
    if ! [ -f "$session_file" ]; then
        exit 0
    fi
    read_session_file "$session_file"
    if [ "$orientation" = "vertical" ]; then
        orientation="horizontal"
    else
        orientation="vertical"
    fi
    write_session_file "$session_file" "$pin_pane" "$size" "$display" "$orientation"
    sync_pane_from_file "$session_file"
elif [ "$command" = "test" ]; then
    if [ -z "$TMUX" ] || [ ! -f "$session_file" ]; then
        exit 1
    fi
    read -r pin_pane < "$session_file"
    [ "$pin_pane" = "$pane_id" ]
fi
