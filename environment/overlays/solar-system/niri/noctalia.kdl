layout {

    focus-ring {
        active-color   "#ffb68b"
        inactive-color "#1a120d"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb68b"
        inactive-color "#1a120d"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb68b"
        inactive-color "#6f3811"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb68b80"
    }
}
