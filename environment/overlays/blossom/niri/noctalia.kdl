layout {

    focus-ring {
        active-color   "#ffb0ca"
        inactive-color "#191114"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb0ca"
        inactive-color "#191114"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb0ca"
        inactive-color "#6f334a"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb0ca80"
    }
}
